# --- AI provider (choose one) ---
AI_PROVIDER=gemini                # "gemini" | "openai"
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Auth ---
NEXTAUTH_SECRET=replace-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# --- Database (Postgres via Prisma-style connection string) ---
DATABASE_URL=postgresql://user:password@localhost:5432/stadiummind

# --- Maps (mocked automatically if absent) ---
NEXT_PUBLIC_MAPBOX_TOKEN=

# --- Rate limiting ---
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=20

# Never commit .env.local — this file is a template only.
